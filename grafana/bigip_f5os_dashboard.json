          "renameByName": { "target": "Target", "lag_name": "LAG", "interface": "Member", "activity": "Activity", "timeout": "Timeout", "synchronization": "Sync" } } }
      ]
    },
    {
      "type": "stat", "title": "LACP Member States (Sync / Collecting / Distributing / Aggregatable)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Boolean LACP member states shown as UP (1, green) / DOWN (0, red): synchronization, collecting, distributing and aggregatable. Any DOWN means the member is not fully bundled.",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 139 }, "id": 52,
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "bigip_f5os_lacp_member_in_sync{target=~\"$target\"}", "legendFormat": "sync {{lag_name}}/{{interface}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "bigip_f5os_lacp_member_collecting{target=~\"$target\"}", "legendFormat": "coll {{lag_name}}/{{interface}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "bigip_f5os_lacp_member_distributing{target=~\"$target\"}", "legendFormat": "dist {{lag_name}}/{{interface}}", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "bigip_f5os_lacp_member_aggregatable{target=~\"$target\"}", "legendFormat": "aggr {{lag_name}}/{{interface}}", "refId": "D" }
      ]
    },
    {
      "type": "timeseries", "title": "LACP PDUs (per second)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Per-second LACP PDU rates (in / out) and RX errors per member, from rate() of the cumulative counters. A stalled in/out rate suggests LACP is not exchanging PDUs.",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 139 }, "id": 53,
      "fieldConfig": { "defaults": { "unit": "pps", "custom": { "drawStyle": "line", "fillOpacity": 5 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(bigip_f5os_lacp_in_packets_total{target=~\"$target\"}[5m])", "legendFormat": "in {{lag_name}}/{{interface}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(bigip_f5os_lacp_out_packets_total{target=~\"$target\"}[5m])", "legendFormat": "out {{lag_name}}/{{interface}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(bigip_f5os_lacp_rx_errors_total{target=~\"$target\"}[5m])", "legendFormat": "rx errors {{lag_name}}/{{interface}}", "refId": "C" }
      ]
    }
  ]
}